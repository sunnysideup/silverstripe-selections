  "require": {
    "silverstripe/framework": "^6.0",
    "silverstripe/admin": "^3.0"
  },
  "require-dev": {
    "sunnysideup/sswebpack_engine_only": "^5.0-dev",
    "silverleague/ideannotator": "*",
    "phpunit/phpunit": "^9.6",
    "squizlabs/php_codesniffer": "^3.7",
    "silverstripe/standards": "^1",
