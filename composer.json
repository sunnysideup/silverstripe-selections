{
  "name": "sunnysideup/selections",
  "description": "Allows the CMS user to access the ORM to create record selections",
  "type": "silverstripe-vendormodule",
  "keywords": [
    "ORM",
    "selection",
    "filter",
    "filtering",
    "sorting",
    "display",
    "gridfield",
    "cms helpers",
    "powerfull",
    "lists",
    "save filters"
  ],
  "license": "BSD-3-Clause",
  "require": {
    "silverstripe/framework": "^5.0",
    "silverstripe/admin": "^2.0",
    "sunnysideup/classes-and-fields-info": "5.x-dev",
    "sunnysideup/add-casted-variables": "5.x-dev",
    "sunnysideup/optionsetfield-grouped": "5.x-dev"
  },
  "require-dev": {
    "sunnysideup/sswebpack_engine_only": "5.x-dev",
    "silverleague/ideannotator": "*",
    "phpunit/phpunit": "^9.6",
    "squizlabs/php_codesniffer": "^3.7",
    "silverstripe/standards": "^1",
    "phpstan/extension-installer": "^1.3",
    "maxime-rainville/anyfield": "dev-main"
